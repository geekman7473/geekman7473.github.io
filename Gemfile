source "https://rubygems.org"

# Jekyll itself. We are NOT using the github-pages gem because we want
# control of the Jekyll version; the site is built locally / by GitHub
# Actions if needed, not by the legacy gh-pages Jekyll builder.
gem "jekyll", "~> 4.4"

# Ruby 3.x ships without webrick, which Jekyll's dev server needs.
gem "webrick", "~> 1.8"
